<svg xmlns="http://www.w3.org/2000/svg" width="1920" height="1080" viewBox="0 0 1920 1080">
  <defs>
    <linearGradient id="gradBg" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#004e89;stop-opacity:1" />
      <stop offset="50%" style="stop-color:#ff6b35;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#f7b801;stop-opacity:1" />
    </linearGradient>
    <pattern id="dots" x="0" y="0" width="100" height="100" patternUnits="userSpaceOnUse">
      <circle cx="50" cy="50" r="3" fill="rgba(255,255,255,0.1)"/>
    </pattern>
  </defs>
  <rect width="1920" height="1080" fill="url(#gradBg)"/>
  <rect width="1920" height="1080" fill="url(#dots)"/>
  <text x="960" y="540" font-size="72" fill="white" text-anchor="middle" dominant-baseline="middle" font-weight="bold" opacity="0.3">FitZone Background</text>
</svg>
